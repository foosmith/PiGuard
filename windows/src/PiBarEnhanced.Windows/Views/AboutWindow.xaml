<Window x:Class="PiBarEnhanced.Windows.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PiBar Enhanced"
        Width="420"
        Height="320"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontSize="28" FontWeight="SemiBold" TextAlignment="Center" Text="PiBar Enhanced" />
            <TextBlock Margin="0,8,0,0" FontSize="14" TextAlignment="Center" Text="Windows Port Foundation" />
            <TextBlock Margin="0,20,0,0"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="#FF666666"
                       Text="Tray-first Windows shell scaffold for the Pi-hole companion app, designed to expand into a fuller desktop application in future phases." />
        </StackPanel>
    </Grid>
</Window>
