<Window x:Class="PiBarEnhanced.Windows.Views.SyncSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Settings"
        Width="900"
        Height="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Sync Settings" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#FF666666"
                       TextWrapping="Wrap"
                       Text="Windows tray app foundation for Pi-hole v6 primary-to-secondary sync. The final Windows implementation will bring over the sync engine, readiness states, activity log, gravity updates, and help affordances from the macOS product." />
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="1" Rows="4">
            <GroupBox Header="Setup" Margin="0,0,0,12">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <CheckBox Content="Enable Primary → Secondary Sync" />
                    <TextBlock Grid.Row="1" Margin="0,12,0,0" Text="Primary" FontWeight="SemiBold" />
                    <ComboBox Grid.Row="2" Margin="0,6,0,0" />
                </Grid>
            </GroupBox>

            <GroupBox Header="Behavior" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock Text="Interval" FontWeight="SemiBold" />
                    <ComboBox Margin="0,6,0,12" Width="160" HorizontalAlignment="Left" />
                    <CheckBox Content="Groups" />
                    <CheckBox Content="Adlists" />
                    <CheckBox Content="Domains" />
                    <CheckBox Margin="0,8,0,0" Content="Preview only (dry run)" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Safety" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <CheckBox Content="Wipe secondary adlists before sync" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FF9A5A00"
                               TextWrapping="Wrap"
                               Text="Use only when you want the secondary rebuilt from scratch." />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Sync Status">
                <StackPanel Margin="12">
                    <TextBlock FontWeight="SemiBold" Text="Status summary and activity log will live here." />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FF666666"
                               TextWrapping="Wrap"
                               Text="The Windows app is being structured to support the same sync-now flow, full-width status treatment, and expandable activity history already implemented on macOS." />
                </StackPanel>
            </GroupBox>
        </UniformGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="110" Margin="0,0,12,0" Content="Sync Now" />
            <Button Width="110" Content="Close" />
        </StackPanel>
    </Grid>
</Window>
