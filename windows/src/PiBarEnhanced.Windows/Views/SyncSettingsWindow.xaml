<Window x:Class="PiBarEnhanced.Windows.Views.SyncSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Settings"
        Width="920"
        Height="680"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Sync Settings" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#FF666666"
                       TextWrapping="Wrap"
                       Text="Configure primary-to-secondary sync for Pi-hole v6 connections and review the last saved sync state." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Header="Setup">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12" Foreground="#FF666666" TextWrapping="Wrap"
                               Text="Choose two Pi-hole v6 connections. The primary is treated as the source of truth; the secondary is updated to match it." />

                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Enable Sync" />
                    <CheckBox x:Name="SyncEnabledCheckBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8"
                              Content="Enable primary to secondary sync" />

                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Primary" />
                    <ComboBox x:Name="PrimaryComboBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id" />

                    <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="Secondary" />
                    <ComboBox x:Name="SecondaryComboBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,0"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Id" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Behavior">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Interval (minutes)" />
                    <ComboBox x:Name="IntervalComboBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,12" Width="180" HorizontalAlignment="Left">
                        <ComboBoxItem Content="5" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="60" />
                    </ComboBox>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                        <TextBlock Margin="0,0,0,8" Foreground="#FF666666" Text="Leave a scope unchecked to skip syncing that category." />
                        <WrapPanel>
                            <CheckBox x:Name="SyncGroupsCheckBox" Margin="0,0,16,8" Content="Groups" />
                            <CheckBox x:Name="SyncAdlistsCheckBox" Margin="0,0,16,8" Content="Adlists" />
                            <CheckBox x:Name="SyncDomainsCheckBox" Margin="0,0,16,8" Content="Domains" />
                            <CheckBox x:Name="DryRunCheckBox" Margin="0,0,16,8" Content="Preview only (dry run)" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Safety">
                <StackPanel Margin="12">
                    <CheckBox x:Name="WipeSecondaryCheckBox" Content="Wipe secondary adlists before sync" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#FF9A5A00"
                               TextWrapping="Wrap"
                               Text="Use this only when you want the secondary rebuilt from scratch. This is the destructive sync option." />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="6" Header="Status">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ReadinessTextBlock" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="LastRunTextBlock" Grid.Row="2" Foreground="#FF666666" TextWrapping="Wrap" />
                    <TextBox x:Name="ActivityTextBox"
                             Grid.Row="4"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="150" />
                </Grid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#FF666666"
                       Text="Save sync settings to persist changes." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Width="110" Margin="0,0,12,0" Content="Save" Click="SaveButton_Click" />
                <Button Width="110" Margin="0,0,12,0" Content="Sync Now" Click="SyncNowButton_Click" />
                <Button Width="100" Content="Close" Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
