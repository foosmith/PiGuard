<Window x:Class="PiGuard.Windows.Views.TrayMiniPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="356"
        Height="284"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid>
        <Grid.Resources>
            <Style x:Key="PanelActionButton" TargetType="Button">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontFamily" Value="Segoe UI Semibold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="14"
                                    Padding="0,1,0,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Chrome" Property="Opacity" Value="0.8" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Chrome" Property="Opacity" Value="0.38" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Border Margin="10,12,10,10"
                CornerRadius="24"
                Background="#22000000">
            <Border.Effect>
                <effects:DropShadowEffect BlurRadius="30"
                                          ShadowDepth="0"
                                          Opacity="0.34"
                                          Color="#000000" />
            </Border.Effect>
        </Border>

        <Border CornerRadius="24"
                BorderThickness="1"
                BorderBrush="#2CFFFFFF"
                Padding="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F1121B28" Offset="0" />
                    <GradientStop Color="#F01B2234" Offset="0.55" />
                    <GradientStop Color="#EC261834" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="PiGuard"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="13"
                                   Foreground="#A8E9F2FF" />
                        <TextBlock x:Name="StatusTextBlock"
                                   Margin="0,5,0,0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="22"
                                   Foreground="White"
                                   Text="PiGuard online" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="9,4"
                            CornerRadius="12"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <SolidColorBrush x:Name="StatusBadgeBrush" Color="#FF179270" />
                        </Border.Background>
                        <TextBlock x:Name="StatusBadgeTextBlock"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="White"
                                   Text="LIVE" />
                    </Border>
                </Grid>

                <UniformGrid Grid.Row="2" Columns="3">
                    <Border Margin="0,0,8,0"
                            Padding="10"
                            CornerRadius="16"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Queries"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="QueriesValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="0" />
                        </StackPanel>
                    </Border>

                    <Border Margin="4,0"
                            Padding="10"
                            CornerRadius="16"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Blocked"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="BlockedValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="0" />
                        </StackPanel>
                    </Border>

                    <Border Margin="8,0,0,0"
                            Padding="10"
                            CornerRadius="16"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Percent"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="PercentValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="20"
                                       Foreground="White"
                                       Text="0.0%" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="4"
                        Padding="12"
                        CornerRadius="18"
                        Background="#14FFFFFF">
                    <StackPanel>
                        <TextBlock Text="Connections"
                                   FontSize="11"
                                   Foreground="#9FD0DAE8" />
                        <TextBlock x:Name="NodesTextBlock"
                                   Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#FFF5F7FB"
                                   Text="No nodes loaded." />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="RefreshButton"
                            Grid.Column="0"
                            Height="38"
                            Style="{StaticResource PanelActionButton}"
                            Background="#1EFFFFFF"
                            Content="Refresh"
                            Click="RefreshButton_Click" />
                    <Button x:Name="EnableButton"
                            Grid.Column="2"
                            Height="38"
                            Style="{StaticResource PanelActionButton}"
                            Background="#CC179270"
                            Content="Enable"
                            Click="EnableButton_Click" />
                    <Button x:Name="DisableButton"
                            Grid.Column="4"
                            Height="38"
                            Style="{StaticResource PanelActionButton}"
                            Background="#CC8E4E2A"
                            Content="Disable"
                            Click="DisableButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
