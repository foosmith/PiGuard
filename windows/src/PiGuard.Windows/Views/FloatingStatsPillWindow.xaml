<Window x:Class="PiGuard.Windows.Views.FloatingStatsPillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="384"
        Height="152"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid>
        <Border Margin="8,10,8,10"
                CornerRadius="22"
                Background="#22000000">
            <Border.Effect>
                <effects:DropShadowEffect BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.32"
                                          Color="#000000" />
            </Border.Effect>
        </Border>

        <Border CornerRadius="22"
                BorderThickness="1"
                BorderBrush="#2CFFFFFF"
                Padding="15,15,15,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EE101A24" Offset="0" />
                    <GradientStop Color="#F0182433" Offset="0.45" />
                    <GradientStop Color="#F0261634" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="PiGuard"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="13"
                                   Foreground="#A8E9F2FF" />
                        <TextBlock x:Name="HeadlineTextBlock"
                                   Margin="0,4,0,0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="21"
                                   Foreground="White"
                                   Text="Online" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="9,4"
                            CornerRadius="12"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <SolidColorBrush x:Name="StatusBadgeBrush" Color="#FF179270" />
                        </Border.Background>
                        <TextBlock x:Name="StatusBadgeTextBlock"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="11"
                                   Foreground="White"
                                   Text="LIVE" />
                    </Border>
                </Grid>

                <UniformGrid Grid.Row="2" Columns="3">
                    <Border Margin="0,0,8,0"
                            Padding="10"
                            CornerRadius="15"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Queries"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="QueriesValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="19"
                                       Foreground="White"
                                       Text="0" />
                        </StackPanel>
                    </Border>

                    <Border Margin="4,0"
                            Padding="10"
                            CornerRadius="15"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Blocked"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="BlockedValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="19"
                                       Foreground="White"
                                       Text="0" />
                        </StackPanel>
                    </Border>

                    <Border Margin="8,0,0,0"
                            Padding="10"
                            CornerRadius="15"
                            Background="#1AFFFFFF">
                        <StackPanel>
                            <TextBlock Text="Percent"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="#9FD0DAE8" />
                            <TextBlock x:Name="PercentValueTextBlock"
                                       Margin="0,3,0,0"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="19"
                                       Foreground="White"
                                       Text="0.0%" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
