<Window x:Class="PiGuard.Windows.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PiGuard"
        Width="420"
        Height="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock FontSize="28" FontWeight="SemiBold" TextAlignment="Center" Text="PiGuard" />
            <TextBlock x:Name="VersionTextBlock"
                       Margin="0,8,0,0"
                       FontSize="13"
                       Foreground="{DynamicResource MutedTextBrush}"
                       TextAlignment="Center" />
            <Button x:Name="GitHubButton"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    Content="View on GitHub"
                    Click="GitHubButton_Click" />
        </StackPanel>
    </Grid>
</Window>
