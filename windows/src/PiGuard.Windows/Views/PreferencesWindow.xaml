<Window x:Class="PiGuard.Windows.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PiGuard Preferences"
        Width="980"
        Height="700"
        MinWidth="920"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Preferences" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#FF666666"
                       TextWrapping="Wrap"
                       Text="Manage Pi-hole connections and the basic tray app behavior for the Windows port." />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Connections">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListView x:Name="ConnectionsListView"
                              SelectionChanged="ConnectionsListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Host" Width="220" DisplayMemberBinding="{Binding DisplayName}" />
                                <GridViewColumn Header="Version" Width="80" DisplayMemberBinding="{Binding VersionLabel}" />
                                <GridViewColumn Header="Auth" Width="120" DisplayMemberBinding="{Binding AuthenticationLabel}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Width="100" Margin="0,0,8,0" Content="New" Click="NewConnectionButton_Click" />
                        <Button Width="100" Margin="0,0,8,0" Content="Delete" Click="DeleteConnectionButton_Click" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#FF666666"
                                   Text="Changes are saved explicitly with Save Changes." />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <GroupBox Header="Connection Details">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Hostname" />
                        <TextBox x:Name="HostnameTextBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Port" />
                        <TextBox x:Name="PortTextBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Version" />
                        <ComboBox x:Name="VersionComboBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" SelectedIndex="1"
                                  SelectionChanged="VersionComboBox_SelectionChanged">
                            <ComboBoxItem Content="Pi-hole v5 or earlier" Tag="LegacyV5" />
                            <ComboBoxItem Content="Pi-hole v6" Tag="V6" />
                            <ComboBoxItem Content="AdGuard Home" Tag="AdGuardHome" />
                        </ComboBox>

                        <TextBlock x:Name="UsernameLabel" Grid.Row="3" VerticalAlignment="Center" Text="Username" Visibility="Collapsed" />
                        <TextBox x:Name="UsernameTextBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,8" Visibility="Collapsed" />

                        <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="Security" />
                        <CheckBox x:Name="UseSslCheckBox"
                                  Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="8,0,0,8"
                                  VerticalAlignment="Center"
                                  Content="Use HTTPS" />

                        <TextBlock Grid.Row="5" VerticalAlignment="Center" Text="Admin URL" />
                        <TextBox x:Name="AdminUrlTextBox" Grid.Row="5" Grid.Column="1" Margin="8,0,0,8" />

                        <TextBlock Grid.Row="6" VerticalAlignment="Center" Text="Secret" />
                        <PasswordBox x:Name="SecretPasswordBox" Grid.Row="6" Grid.Column="1" Margin="8,0,0,8" />

                        <TextBlock Grid.Row="7" VerticalAlignment="Center" Text="Secret Behavior" />
                        <CheckBox x:Name="PasswordProtectedCheckBox"
                                  Grid.Row="7"
                                  Grid.Column="1"
                                  Margin="8,0,0,8"
                                  VerticalAlignment="Center"
                                  Content="Connection requires token/app password" />

                        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Margin="0,12,0,0" VerticalAlignment="Bottom">
                            <TextBlock Foreground="#FF666666"
                                       TextWrapping="Wrap"
                                       Text="For v5 connections, store the API token here. For v6 connections, store the app password. For AdGuard Home, store the password here and enter the username above. Leaving the secret blank while editing keeps the existing stored secret." />
                            <Button x:Name="TestConnectionButton"
                                    Width="160"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Left"
                                    Content="Test Connection"
                                    Click="TestConnectionButton_Click" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="App Behavior">
                    <StackPanel Margin="12">
                        <CheckBox x:Name="LaunchAtStartupCheckBox" Margin="0,0,0,10" Content="Launch at startup" />
                        <CheckBox x:Name="ShortcutEnabledCheckBox" Margin="0,0,0,10" Content="Enable global hotkey (Ctrl+Alt+Shift+P)"
                                  ToolTip="Quickly toggle blocking on all configured servers from anywhere" />
                        <CheckBox x:Name="EnableLoggingCheckBox" Margin="0,0,0,10" Content="Enable diagnostic logging" />
                        <CheckBox x:Name="EnableFloatingStatsPillCheckBox" Margin="0,0,0,10" Content="Show floating stats pill" />
                        <CheckBox x:Name="EnableTrayMiniPanelCheckBox" Margin="0,0,0,10" Content="Show mini panel on tray click" />
                        <CheckBox x:Name="EnableRichTrayTooltipCheckBox" Margin="0,0,0,10" Content="Use richer tray hover text" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="Polling rate (seconds)" />
                            <TextBox x:Name="PollingRateTextBox" Width="80" Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#FF666666"
                       Text="Load or create a connection, then save changes." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button x:Name="SaveChangesButton" Width="120" Margin="0,0,12,0" Content="Save Changes" Click="SaveChangesButton_Click" />
                <Button Width="100" Content="Close" Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
